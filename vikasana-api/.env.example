# ─────────────────────────────────────────────────────────
# Vikasana Foundation API — Environment Configuration
# Copy to .env → cp .env.example .env
# ─────────────────────────────────────────────────────────

# PostgreSQL (async driver for FastAPI)
DATABASE_URL=postgresql+asyncpg://admin:StrongPass@123@127.0.0.1:5433/appdb
# PostgreSQL (sync driver for Alembic migrations)
DATABASE_SYNC_URL=postgresql://admin:StrongPass@123@127.0.0.1:5433/appdb

# Connection Pool (for 2000+ concurrent users)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# JWT
SECRET_KEY=replace_me_with_secrets_token_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# App
APP_ENV=production
DEBUG=false

# Certificate QR Verification
CERT_SIGNING_SECRET=replace_me
PUBLIC_BASE_URL=https://yourdomain.com

# MinIO / S3
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_FACULTY=vikasana-faculty
MINIO_BUCKET_ACTIVITIES=activity-uploads
MINIO_BUCKET_EVENT_THUMBNAILS=vikasana-event-thumbnails
MINIO_FACE_BUCKET=face-verification
MINIO_BUCKET_CERTIFICATES=vikasana-certificates
MINIO_SECURE=false
MINIO_PUBLIC_BASE=

# Email (Brevo)
SENDINBLUE_API_KEY=
EMAIL_FROM=admin@vikasana.org
EMAIL_FROM_NAME=Vikasana Foundation

# Faculty Activation
FRONTEND_BASE_URL=http://localhost:5173
ACTIVATION_TOKEN_SECRET=secret
ACTIVATION_TOKEN_EXPIRE_HOURS=48

# Celery (Background Workers)
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
